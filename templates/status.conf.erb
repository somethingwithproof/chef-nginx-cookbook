server {
    listen 127.0.0.1:80;
    server_name localhost;
    
    # Status location
    location <%= @status_path %> {
        stub_status on;
        
        <% if @restricted_access %>
        # Restrict access
        <% @allowed_ips.each do |ip| %>
        allow <%= ip %>;
        <% end %>
        deny all;
        <% end %>
    }
}